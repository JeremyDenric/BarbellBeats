# BarbellBeats — Environment Variables
# Copy to .env.local for local development. Never commit .env.local (it is gitignored).
# Variables prefixed EXPO_PUBLIC_ are bundled into the JS layer and safe to expose.
# Non-prefixed variables used in app.config.js are build-time only (not in JS bundle).

# ── Backend ───────────────────────────────────────────────────────────────────
# Leave blank in dev — the app defaults to http://localhost:3000/api
EXPO_PUBLIC_API_URL=

# ── Spotify OAuth ─────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# Add redirect URI: exp://localhost:8081 (Expo Go) or your custom scheme
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id

# ── Google Sign-In ────────────────────────────────────────────────────────────
# Web Client ID from https://console.cloud.google.com/apis/credentials
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id

# ── Google Maps ───────────────────────────────────────────────────────────────
# Build-time native key — injected into iOS Info.plist and Android manifest
# via app.config.js. NOT prefixed EXPO_PUBLIC_ because it is not bundled into
# the JS layer. Restrict this key in Google Cloud Console to your bundle ID:
#   iOS: com.jeremydenric.barbellbeats
#   Android: com.jeremydenric.barbellbeats
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── RevenueCat (in-app subscriptions) ────────────────────────────────────────
# Public SDK keys — safe to expose (server-side validation happens via RevenueCat)
# Get from: https://app.revenuecat.com → Project → API Keys → Public SDK keys
# iOS key starts with "appl_", Android key starts with "goog_"
EXPO_PUBLIC_RC_API_KEY_IOS=
EXPO_PUBLIC_RC_API_KEY_ANDROID=

# ── Error monitoring (Sentry) ─────────────────────────────────────────────────
# Get DSN from: https://sentry.io → Project → Settings → Client Keys (DSN)
# Optional in dev; required for production crash reporting
SENTRY_DSN=
