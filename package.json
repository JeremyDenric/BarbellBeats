{
  "name": "barbellbeats",
  "version": "1.0.0",
  "main": "index.js",
  "description": "BarbellBeats - A real-time, social music platform for gyms with democratic voting and ranking",
  "private": true,
  "workspaces": [
    "server",
    "shared"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "dev": "expo start",
    "dev:frontend": "expo start",
    "dev:backend": "cd server && npm run dev",
    "test": "npm run test:frontend && npm run test:backend",
    "test:backend": "cd server && npm test",
    "test:frontend": "jest",
    "build:frontend:ios": "expo build:ios",
    "build:frontend:android": "expo build:android",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "android": "expo run:android",
    "ios": "expo run:ios"
  },
  "keywords": [
    "gym",
    "music",
    "social",
    "realtime",
    "aws",
    "serverless",
    "react-native"
  ],
  "author": "Your Name",
  "license": "MIT",
  "overrides": {
    "xml2js": "^0.6.2",
    "semver": "^7.6.2"
  },
