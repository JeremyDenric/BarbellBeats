{
  "name": "hono-backend",
  "version": "1.0.0",
  "description": "Modern Hono backend with TypeScript",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": [
    "hono",
    "typescript",
    "api",
    "backend",
    "rest"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@prisma/client": "^6.16.0",
    "bcrypt": "^6.0.0",
    "hono": "^4.5.0",
    "jose": "^5.2.4",
    "ngeohash": "^0.6.3",
    "nodemailer": "^7.0.12",
    "redis": "^4.7.1",
    "winston": "^3.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "node-gyp-build": "^4.8.0",
    "@types/bcrypt": "^5.0.2",
    "@types/ngeohash": "^0.6.8",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^9.39.2",
    "prettier": "^3.3.2",
    "prisma": "^6.16.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.16"
  }
}
